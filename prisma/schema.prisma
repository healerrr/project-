generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Project {
  id            String           @id @default(cuid())
  name          String
  slug          String           @unique
  alias         String           @default("")
  gitlabUrl     String           @default("")
  testEnvironment String         @default("")
  testAccount   String           @default("")
  testPassword  String           @default("")
  productionEnvironment String   @default("")
  testServer    String           @default("")
  developer     String           @default("")
  type          String
  description   String
  websiteUrl    String
  repositoryUrl String
  owner         String
  icon          String
  accent        String
  tags          String           @default("[]")
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  runtimes      ProjectRuntime[]
}

model ProjectRuntime {
  id              String    @id @default(cuid())
  projectId       String
  environment     String
  status          String
  healthCheckType String
  healthCheckUrl  String?
  serverHost      String
  serverOs        String
  startMethod     String
  startCommand    String?
  responseTime    Int?
  lastCheckedAt   DateTime?
  lastDeployAt    DateTime?
  remark          String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  project         Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, environment])
  @@index([status])
  @@index([environment])
}
